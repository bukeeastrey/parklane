{
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src * blob: data: 'unsafe-inline' 'unsafe-eval';" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
